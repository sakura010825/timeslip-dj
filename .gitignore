# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# TTS archive (運営者ローカルの音声アーカイブ・コミットしない)
/.tts-archive/

# TTS provider evaluation samples (比較試聴用・コミットしない)
/.tts-eval/
/.tts-variant-test/

# .env.local の手動バックアップ（Azure復帰用など）
.env.local.backup-*
/.tts-snapshot-test/

# ワーカー常駐ランチャのログ（T0-4・start-worker.bat が出力）
/logs/

# ショート生成物（大容量mp4・キャッシュ）
output/shorts/

# 長尺アンカー生成物（T2-6・数十MBのmp4・サムネ・ASS）
output/anchors/

# ショート用フォント（システムからコピー・バイナリはコミットしない）
assets/shorts/fonts/*.ttf
assets/shorts/fonts/*.ttc

# ショート背景画像（生成物・バイナリはコミットしない／PROMPTS.mdは残す）
assets/shorts/backgrounds/*.png
assets/shorts/backgrounds/*.jpg
# ただし長尺アンカーの共通背景だけは例外＝公開動画3本の見た目を決める資産で、
# Geminiは同じ絵を二度と出さない。原本と作り方は redial/SNS/README.md（2026-07-16）
!assets/shorts/backgrounds/radio-booth-night.png
